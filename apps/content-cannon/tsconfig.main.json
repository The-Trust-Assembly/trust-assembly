{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist/main",
    "rootDir": "./src/main",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/main/**/*"]
}
