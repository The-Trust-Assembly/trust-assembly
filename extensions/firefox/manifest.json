{
  "manifest_version": 2,
  "name": "Trust Assembly",
  "version": "1.0.0",
  "description": "Truth Will Out. Overlay community-verified corrections, affirmations, and translations on any webpage.",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api-client.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@trustassembly.org",
      "strict_min_version": "109.0"
    }
  }
}
