{
  "manifest_version": 2,
  "name": "Trust Assembly",
  "version": "1.0.0",
  "description": "Truth Will Out. Overlay community-verified corrections, affirmations, and translations on any webpage.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api-client.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    "icon48.png",
    "icon48-corrected.png",
    "icon48-affirmed.png",
    "icon48-pending.png",
    "icon128.png",
    "icon128-corrected.png",
    "icon128-affirmed.png",
    "icon128-pending.png"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@trustassembly.org",
      "strict_min_version": "109.0",
	  "data_collection_permissions": {
		  "description": "This extension checks on our server if the website the user is viewing requires correction, and may edit the site based on that.",
		  "consent_url": "https://trustassembly.org/",
		  "data_types": ["personal_data"],
		  "required": ["authenticationInfo", "websiteContent"]
	  }
    }
  }
}
