{
  "manifest_version": 3,
  "name": "Trust Assembly",
  "version": "1.0.0",
  "description": "Truth Will Out. Overlay community-verified corrections, affirmations, and translations on any webpage.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api-client.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon128.png",
        "icon128-corrected.png",
        "icon128-affirmed.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
